<!DOCTYPE html>
<html lang="ar" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>al_witify Medical Quiz</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00f2fe;
            --primary-glow: rgba(0, 242, 254, 0.6);
            --gold: #FFD700;
            --gold-light: #FFDF00;
            --gold-dark: #D4AF37;
            --correct: #2ecc71;
            --wrong: #e74c3c;
            --bg-dark: #050510;
            --text-light: #f5f6fa;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Tajawal', sans-serif;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Animated Galaxy Background */
        .galaxy-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -3;
            background: radial-gradient(circle at 20% 50%, rgba(20, 30, 80, 0.4), transparent 50%),
                        radial-gradient(circle at 80% 80%, rgba(80, 20, 80, 0.3), transparent 60%),
                        var(--bg-dark);
            background-size: 200% 200%;
            animation: galaxyPan 40s ease-in-out infinite alternate;
        }

        @keyframes galaxyPan {
            0% { background-position: 0% 0%; }
            100% { background-position: 100% 100%; }
        }

        /* Slowly Moving Stars */
        .stars-container {
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            z-index: -2;
            pointer-events: none;
            animation: rotateStars 200s linear infinite;
        }

        @keyframes rotateStars {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @keyframes twinkle {
            0%, 100% { opacity: 0.2; transform: scale(0.8); }
            50% { opacity: 1; transform: scale(1.2); }
        }

        /* Enhanced Shooting Stars */
        .shooting-star {
            position: fixed;
            width: 150px;
            height: 2px;
            background: linear-gradient(90deg, rgba(255,255,255,1), rgba(255,255,255,0));
            animation: shooting 4s linear infinite;
            opacity: 0;
            z-index: -1;
            filter: drop-shadow(0 0 10px white);
        }
        .shooting-star::before {
            content: '';
            position: absolute;
            width: 4px;
            height: 4px;
            background: #fff;
            border-radius: 50%;
            box-shadow: 0 0 15px 3px #fff;
            top: -1px;
            left: 0;
        }

        @keyframes shooting {
            0% { transform: translateX(120vw) translateY(-20vh) rotate(35deg); opacity: 1; }
            30% { opacity: 0; }
            100% { transform: translateX(-50vw) translateY(100vh) rotate(35deg); opacity: 0; }
        }

        /* App Containers */
        #home, #quiz-container {
            width: 100%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s ease;
        }

        #quiz-container {
            display: none;
            justify-content: flex-start;
            padding: 100px 20px 40px 20px; /* Space for fixed header */
        }

        /* Radiant Golden Name */
        h1.name-title {
            font-family: 'Cinzel', serif;
            font-size: 6rem;
            font-weight: 900;
            background: linear-gradient(45deg, var(--gold-dark), var(--gold-light), #fff, var(--gold-light), var(--gold-dark));
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shineGold 4s linear infinite, float 4s ease-in-out infinite;
            text-shadow: 
                0 0 20px rgba(255, 215, 0, 0.4),
                0 0 40px rgba(255, 215, 0, 0.2),
                0 0 60px rgba(255, 215, 0, 0.1);
            margin-bottom: 60px;
            text-align: center;
            letter-spacing: 2px;
        }

        @keyframes shineGold { to { background-position: 200% center; } }
        
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        /* Neon Buttons */
        .levels-container {
            display: flex;
            flex-direction: column;
            gap: 25px;
            position: relative;
        }

        /* Background glow for the buttons area */
        .levels-container::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 150%;
            height: 150%;
            background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
            opacity: 0.1;
            z-index: -1;
            filter: blur(40px);
        }

        .level-btn {
            background: rgba(0, 0, 0, 0.6);
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 18px 50px;
            font-size: 1.8rem;
            font-family: 'Cinzel', serif;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 300px;
            text-align: center;
            font-weight: 900;
            box-shadow: 0 0 15px var(--primary-glow), inset 0 0 15px var(--primary-glow);
            text-shadow: 0 0 8px var(--primary);
            letter-spacing: 3px;
        }

        .level-btn:hover {
            background: var(--primary);
            color: #000;
            box-shadow: 0 0 30px var(--primary), 0 0 60px var(--primary), inset 0 0 10px rgba(255,255,255,0.5);
            transform: scale(1.05);
            text-shadow: none;
        }

        /* Fixed Quiz Header */
        .quiz-header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 15px 5%;
            background: rgba(5, 5, 16, 0.85);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            border-bottom: 1px solid rgba(0, 242, 254, 0.3);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }

        .score-board {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--gold);
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
        }

        .back-btn {
            background: transparent;
            border: 1px solid var(--primary);
            color: var(--primary);
            padding: 8px 20px;
            border-radius: 20px;
            cursor: pointer;
            transition: 0.3s;
            font-size: 1.1rem;
            font-weight: bold;
            box-shadow: 0 0 10px var(--primary-glow);
        }
        .back-btn:hover { 
            background: var(--primary);
            color: #000;
            box-shadow: 0 0 20px var(--primary);
        }

        /* Questions Area */
        #questions-area {
            width: 100%;
            max-width: 800px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .question-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            width: 100%;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .question-text {
            font-size: 1.3rem;
            margin-bottom: 25px;
            line-height: 1.6;
            font-weight: 700;
            color: #fff;
        }

        .options-grid {
            display: grid;
            gap: 15px;
        }

        .option-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #e0e0e0;
            padding: 16px 20px;
            border-radius: 12px;
            cursor: pointer;
            text-align: left;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            position: relative;
        }

        .option-btn:hover:not(.disabled) {
            background: rgba(0, 242, 254, 0.1);
            border-color: var(--primary);
            transform: translateX(10px);
            color: #fff;
        }

        .option-btn.correct {
            background: rgba(46, 204, 113, 0.2);
            border-color: var(--correct);
            color: #fff;
            box-shadow: 0 0 15px rgba(46, 204, 113, 0.4);
            font-weight: bold;
        }

        .option-btn.wrong {
            background: rgba(231, 76, 60, 0.2);
            border-color: var(--wrong);
            color: #fff;
            box-shadow: 0 0 15px rgba(231, 76, 60, 0.4);
        }

        .disabled { pointer-events: none; }

        /* Floating Emojis */
        .floating-emoji {
            position: fixed;
            font-size: 3rem;
            pointer-events: none;
            animation: floatUp 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            z-index: 2000;
        }

        @keyframes floatUp {
            0% { transform: translateY(0) scale(0.5); opacity: 1; }
            100% { transform: translateY(-150px) scale(1.5); opacity: 0; }
        }

        /* Responsive Design for iPad & Mobile */
        @media (max-width: 1024px) {
            h1.name-title { font-size: 5rem; }
            .question-card { padding: 25px; }
        }

        @media (max-width: 768px) {
            h1.name-title { font-size: 4rem; margin-bottom: 40px; }
            .level-btn { width: 260px; padding: 15px 40px; font-size: 1.5rem; }
            .question-text { font-size: 1.15rem; }
            .option-btn { font-size: 1rem; padding: 14px; }
            #quiz-container { padding-top: 90px; }
        }

        @media (max-width: 480px) {
            h1.name-title { font-size: 2.8rem; letter-spacing: 1px; margin-bottom: 30px; }
            .level-btn { width: 80%; max-width: 250px; padding: 12px; font-size: 1.3rem; border-width: 1px;}
            .quiz-header { padding: 12px 15px; }
            .score-board { font-size: 1.2rem; }
            .back-btn { font-size: 0.9rem; padding: 6px 15px; }
            .question-card { padding: 20px 15px; border-radius: 15px; }
            .question-text { font-size: 1.05rem; }
            .option-btn { font-size: 0.95rem; padding: 12px; }
            .option-btn:hover:not(.disabled) { transform: none; background: rgba(0, 242, 254, 0.2); }
        }
    </style>
</head>
