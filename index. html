        const keys = {
            L1: "1-C 2-B 3-C 4-D 5-A 6-B 7-C 8-D 9-B 10-B 11-A 12-B 13-D 14-C 15-D 16-B 17-C 18-C 19-A 20-D 21-B 22-A 23-C 24-C 25-B 26-D 27-C 28-B 29-D 30-A 31-A 32-B 33-B 34-D 35-D",
            L2: "1-A 2-B 3-C 4-D 5-B 6-C 7-C 8-D 9-C 10-B 11-D 12-B 13-C 14-B 15-D 16-C 17-C 18-B 19-B 20-C 21-C 22-B 23-C 24-B 25-B 26-D 27-C 28-B 29-C 30-D 31-A 32-B 33-C 34-D 35-D",
            L3: "1-A 2-B 3-B 4-C 5-B 6-B 7-C 8-D 9-B 10-B 11-B 12-B 13-B 14-B 15-C 16-B 17-B 18-C 19-B 20-C 21-B 22-B 23-C 24-B 25-B 26-B 27-B 28-B 29-B 30-B 31-B 32-B 33-B 34-D 35-D"
        };

        function parseData(level) {
            const rawText = rawTexts[level];
            const keyStr = keys[level];
            
            const ansMap = {};
            keyStr.split(' ').forEach(pair => {
                const parts = pair.split('-');
                ansMap[parts[0]] = parts[1];
            });

            const questions = [];
            const blocks = rawText.split(/\n(?=\d+\.\s)/);

            blocks.forEach((block, idx) => {
                if(!block.trim()) return;
                const lines = block.split('\n').map(l => l.trim()).filter(l => l);
                
                let qText = lines[0];
                if(idx === 0) qText = qText.replace(/^\d+\.\s*/, `${idx+1}. `);
                
                const qNumStr = qText.match(/^(\d+)/);
                if(!qNumStr) return;
                const qNum = qNumStr[1];
                
                const opts = lines.slice(1).filter(l => /^[A-D]\./.test(l));
                
                const correctLetter = ansMap[qNum];
                const correctIndex = ['A', 'B', 'C', 'D'].indexOf(correctLetter);

                questions.push({
                    text: qText,
                    options: opts,
                    correctIndex: correctIndex
                });
            });

            return questions;
        }

        // --- Logic Engine ---
        let currentScore = 0;
        
        function startQuiz(level) {
            initAudio(); 
            document.getElementById('home').style.display = 'none';
            document.getElementById('quiz-container').style.display = 'flex';
            
            const questions = parseData(level);
            currentScore = 0;
            document.getElementById('score').innerText = currentScore;
            document.getElementById('total').innerText = questions.length;
            
            renderQuestions(questions);
            window.scrollTo(0, 0);
        }

        function goHome() {
            document.getElementById('quiz-container').style.display = 'none';
            document.getElementById('home').style.display = 'flex';
            document.getElementById('questions-area').innerHTML = '';
        }

        function renderQuestions(questions) {
            const container = document.getElementById('questions-area');
            container.innerHTML = '';

            questions.forEach((q, qIndex) => {
                const card = document.createElement('div');
                card.className = 'question-card';
                
                const title = document.createElement('div');
                title.className = 'question-text';
                title.innerText = q.text;
                card.appendChild(title);

                const optsGrid = document.createElement('div');
                optsGrid.className = 'options-grid';

                q.options.forEach((optText, optIndex) => {
                    const btn = document.createElement('button');
                    btn.className = 'option-btn';
                    btn.innerText = optText;
                    
                    // Add touch event explicitly for mobile devices along with click
                    btn.addEventListener('click', (e) => handleAnswer(e, btn, optsGrid, optIndex === q.correctIndex, q.correctIndex));
                    
                    optsGrid.appendChild(btn);
                });

                card.appendChild(optsGrid);
                container.appendChild(card);
            });
        }

        function handleAnswer(e, selectedBtn, gridElement, isCorrect, correctIndex) {
            if(selectedBtn.classList.contains('disabled')) return; // Prevent double trigger
            
            const buttons = gridElement.querySelectorAll('.option-btn');
            buttons.forEach(btn => btn.classList.add('disabled'));

            if (isCorrect) {
                selectedBtn.classList.add('correct');
                currentScore++;
                document.getElementById('score').innerText = currentScore;
                playSound('correct');
            } else {
                selectedBtn.classList.add('wrong');
                buttons[correctIndex].classList.add('correct');
                playSound('wrong');
            }

            for(let i=0; i<6; i++) {
                setTimeout(() => showFloatingEmoji(e, isCorrect), i * 100);
            }
        }
    </script>
