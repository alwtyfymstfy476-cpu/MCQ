    <script>
        // --- Web Audio API for Sound Effects ---
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        let audioCtx;

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new AudioContext();
            }
        }

        function playSound(type) {
            if (!audioCtx) return;
            if (audioCtx.state === 'suspended') audioCtx.resume();
            
            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);

            if (type === 'correct') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(600, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(1500, audioCtx.currentTime + 0.15);
                gainNode.gain.setValueAtTime(0.2, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
                osc.start();
                osc.stop(audioCtx.currentTime + 0.5);
            } else {
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(200, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(50, audioCtx.currentTime + 0.3);
                gainNode.gain.setValueAtTime(0.2, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
                osc.start();
                osc.stop(audioCtx.currentTime + 0.4);
            }
        }

        // --- Visual Effects ---
        function generateStars() {
            const starsContainer = document.getElementById('stars');
            for(let i=0; i<300; i++) { // Increased number of stars
                let star = document.createElement('div');
                star.style.position = 'absolute';
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.width = Math.random() * 2.5 + 'px';
                star.style.height = star.style.width;
                star.style.backgroundColor = '#ffffff';
                star.style.borderRadius = '50%';
                star.style.opacity = Math.random();
                star.style.boxShadow = `0 0 ${Math.random() * 5}px white`;
                star.style.animation = `twinkle ${Math.random() * 4 + 3}s infinite alternate`;
                starsContainer.appendChild(star);
            }
        }
        generateStars();

        const emojis = {
            correct: ['🎉', '✨', '🔥', '🌟', '😎', '👏', '✅', '🚀', '💯', '👑', '🏆'],
            wrong: ['❌', '😢', '💔', '💀', '🤔', '📉', '⚠️', '🤦', '😶', '🤕', '👎']
        };

        function showFloatingEmoji(e, isCorrect) {
            const arr = isCorrect ? emojis.correct : emojis.wrong;
            const char = arr[Math.floor(Math.random() * arr.length)];
            
            const el = document.createElement('div');
            el.className = 'floating-emoji';
            el.innerText = char;
            
            // Randomize position slightly around the center of the screen if e is null, else near click
            let x, y;
            if (e.touches && e.touches.length > 0) {
                x = e.touches[0].clientX;
                y = e.touches[0].clientY;
            } else {
                x = e.clientX;
                y = e.clientY;
            }

            const offsetX = (Math.random() - 0.5) * 80;
            const offsetY = (Math.random() - 0.5) * 80;
            
            el.style.left = (x + offsetX - 25) + 'px';
            el.style.top = (y + offsetY - 25) + 'px';
            
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 1000);
        }

